# LLM 설정 (anthropic | openai | google_genai)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=your-api-key-here
# 개발 시 타임아웃 재시도 폭주 방지 (0=즉시 실패, 프로덕션은 삭제하거나 2로 설정)
# LLM_MAX_RETRIES=0

# 임베딩 설정 (huggingface | openai | google_genai)
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3

# 백엔드 API URL
BACKEND_URL=http://localhost:8080

# ChromaDB 경로
CHROMA_DB_PATH=./chroma_db

# RAG 소스 파일 경로
POLICY_PDF_PATH=./data/2026학년도학교급식기본계획.pdf
GUIDELINES_PDF_PATH=./data/학교급식_식단작성_참고자료.pdf
FOOD_DB_EXCEL_PATH=./data/20251229_음식DB 19495건.xlsx

# LangSmith 트레이싱 (선택)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=hololog-ai
LANGCHAIN_API_KEY=your-langsmith-key-here
